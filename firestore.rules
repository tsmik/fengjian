rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // settings 集合：完全開放讀（teacher 通道無 Firebase Auth 也要能讀題目/規則/updateLog）；
    // 寫仍限制 admin
    match /settings/{doc} {
      allow read: if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // users 集合：使用者只能讀寫自己的資料
    // 例外：teacher-shared / teacher2-shared 兩個共用帳號免 Firebase Auth（給老師/師母用 ?role=teacher 通道）
    match /users/{userId} {
      allow read, write: if (request.auth != null && request.auth.uid == userId) ||
                            userId == 'teacher-shared' ||
                            userId == 'teacher2-shared';

      match /cases/{caseId} {
        allow read, write: if (request.auth != null && request.auth.uid == userId) ||
                              userId == 'teacher-shared' ||
                              userId == 'teacher2-shared';
      }
    }

    // mobileUsers 集合：手機版用，無 Auth，完全開放
    match /mobileUsers/{name} {
      allow read, write: if true;
    }

    // analyses 集合：已登入使用者可寫
    match /analyses/{doc} {
      allow write: if request.auth != null;
    }

    // 白名單：登入使用者可讀，只有 admin 可寫
    match /allowedUsers/{email} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // photo_training：保持開放（訓練用）
    match /photo_training/{docId} {
      allow read, write: if true;
    }
  }
}
